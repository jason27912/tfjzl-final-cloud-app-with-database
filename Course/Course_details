<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ course.name }} - Online Course</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h1 class="h3 mb-0">{{ course.name }}</h1>
                    </div>
                    <div class="card-body">
                        <p class="lead">{{ course.description }}</p>
                        <hr>
                        <h3>Lessons</h3>
                        <div class="list-group">
                            {% for lesson in course.lessons.all|dictsort:"order" %}
                                <div class="list-group-item">
                                    <h4 class="h5">{{ lesson.title }}</h4>
                                    <p>{{ lesson.content|truncatewords:30 }}</p>
                                    {% if lesson.questions.exists %}
                                        <a href="{% url 'course:take_exam' lesson.id %}" class="btn btn-sm btn-success">Take Exam</a>
                                    {% endif %}
                                </div>
                            {% empty %}
                                <p>No lessons available yet.</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
